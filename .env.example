# Skopíruj tento súbor ako `.env` a doplň hodnoty.
# Rovnaké premenné sú nastavené aj vo Verceli (Project → Settings → Environment Variables).

# Verejný Mapbox token pre interaktívnu mapu.
# Získaš na https://account.mapbox.com/access-tokens/ alebo skopíruj z Vercelu.
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAI kľúč pre AI plánovač (bez neho použije plánovač ukážkový itinerár).
# Získaš na https://platform.openai.com/api-keys
OPENAI_API_KEY=
